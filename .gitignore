cat > .gitignore << 'EOF'
# Secrets
.env

# Python
__pycache__/
*.pyc
.venv/
venv/
.envrc

# Local outputs
*.json
*.jsonl
*.parquet

/tmp/

# OS / Editor
.DS_Store
.vscode/
EOF

!config/skills_dictionary.json

logs/
